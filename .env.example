# --- PepTrack Growth OS — environment ---
# The dashboard RUNS WITHOUT these (demo mode with sample data). Set them to use
# your live Supabase project. Never commit the real .env.

# Supabase project (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ... # anon/public key (RLS-protected; safe in client)

# Server-only privileged key — used by server components/route handlers to read &
# write past RLS for this internal admin tool. NEVER expose to the client / NEXT_PUBLIC.
SUPABASE_SERVICE_ROLE_KEY=eyJ... # service_role key (Settings → API)

# Simple gate for the dashboard (comma-separated admin emails allowed to sign in).
ADMIN_EMAILS=jordan@getplnr.com

# App + attribution
NEXT_PUBLIC_APP_STORE_URL=https://apps.apple.com/app/id6772598337
NEXT_PUBLIC_SITE_URL=https://peptrack-marketing.vercel.app

# Email sending (DRAFT-FIRST: only used for approved sends; leave blank to disable)
RESEND_API_KEY=
RESEND_FROM="PepTrack <hello@peptrack.ai>"
